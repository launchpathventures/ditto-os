{
  "name": "agent-os",
  "version": "0.1.0",
  "description": "The universal platform for human-agent collaboration",
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "dev-pipeline": "tsx src/dev-pipeline.ts",
    "dev-bot": "tsx src/dev-bot.ts"
  },
  "keywords": [
    "agents",
    "ai",
    "orchestration",
    "human-in-the-loop"
  ],
  "author": "Launch Path Ventures",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@clack/prompts": "^1.1.0",
    "better-sqlite3": "^11.9.1",
    "citty": "^0.2.1",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
