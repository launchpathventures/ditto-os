{
  "name": "ditto",
  "version": "0.1.0",
  "description": "AI that gets better every time you work with it",
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auto": "expect-cli -a claude -y --target changes",
    "type-check": "tsc --noEmit",
    "dev": "pnpm --filter @ditto/web dev",
    "dev-pipeline": "tsx src/dev-pipeline.ts",
    "dev-bot": "tsx src/dev-bot.ts"
  },
  "keywords": [
    "agents",
    "ai",
    "orchestration",
    "human-in-the-loop"
  ],
  "author": "Launch Path Ventures",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@clack/prompts": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "agentmail": "^0.4.17",
    "better-sqlite3": "^11.9.1",
    "citty": "^0.2.1",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "openapi-types": "^12.1.3",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.10",
    "expect-cli": "^0.0.18",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
