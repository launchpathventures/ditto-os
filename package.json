{
  "name": "ditto",
  "version": "0.1.0",
  "description": "AI that gets better every time you work with it",
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run --exclude src/engine/journey-smoke.test.ts",
    "test:watch": "vitest",
    "test:journey": "vitest run src/engine/journey-smoke.test.ts --testTimeout 120000",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auto": "expect-cli -a claude -y --target changes",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit && pnpm --filter @ditto/web build",
    "dev": "pnpm --filter @ditto/web dev",
    "ditto:sync": "tsx src/scripts/validate-templates.ts",
    "dev-pipeline": "tsx src/dev-pipeline.ts",
    "dev-bot": "tsx src/dev-bot.ts"
  },
  "keywords": [
    "agents",
    "ai",
    "orchestration",
    "human-in-the-loop"
  ],
  "author": "Launch Path Ventures",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@apidevtools/swagger-parser": "^12.1.0",
    "@browserbasehq/stagehand": "^3.2.1",
    "@clack/prompts": "^1.1.0",
    "@ditto/core": "workspace:*",
    "@elevenlabs/elevenlabs-js": "^2.42.0",
    "@google/generative-ai": "^0.24.1",
    "@lancedb/lancedb": "^0.27.2",
    "@supabase/supabase-js": "^2.103.0",
    "agentmail": "^0.4.17",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.9.1",
    "cheerio": "^1.2.0",
    "citty": "^0.2.1",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.41.1",
    "isomorphic-git": "^1.37.5",
    "jsonrpc-lite": "^2.2.0",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "openapi-types": "^12.1.3",
    "pdf-parse": "^2.4.5",
    "stripe": "^22.0.0",
    "svix": "^1.90.0",
    "typescript": "^5.9.3",
    "unipile-node-sdk": "^1.9.3",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "expect-cli": "^0.0.18",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
