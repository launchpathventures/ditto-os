# Agent OS — Environment Variables

# Database
# SQLite — auto-created at data/agent-os.db. No configuration needed.
# Schema is synced automatically via `pnpm cli sync`.

# Anthropic (for Claude agent adapter)
ANTHROPIC_API_KEY=sk-ant-...

# Agent defaults
DEFAULT_AGENT_MODEL=claude-sonnet-4-6

# Dev Pipeline — Telegram Bot (optional)
# Create a bot via @BotFather on Telegram, get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
