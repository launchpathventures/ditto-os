# Ditto — Environment Variables

# Database
# SQLite — auto-created at data/ditto.db. No configuration needed.
# Schema is synced automatically via `pnpm cli sync`.

# ============================================================
# LLM Providers (ADR-026: multi-provider purpose routing)
# ============================================================
# Ditto loads ALL providers with configured API keys simultaneously.
# Routes to the best model per task: conversation → best model,
# classification → cheapest model. Set at least one key.
#
# All configured providers are available. No LLM_PROVIDER needed
# unless using Ollama (single-provider override).

# Anthropic (Claude) — best for conversation and writing
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT) — strong alternative for all purposes
# OPENAI_API_KEY=sk-...

# Google (Gemini) — cost-effective for classification and extraction
# GOOGLE_AI_API_KEY=...

# Ollama (local, free) — single-provider override, no purpose routing
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.3
# OLLAMA_URL=http://localhost:11434

# Development mode — mock responses, no API keys needed
# MOCK_LLM=true

# ============================================================
# Web Search — Perplexity Sonar API (optional)
# ============================================================
# Enables Alex to search the web in real-time during conversations.
# Sign up at https://www.perplexity.ai/ for an API key.
# PERPLEXITY_API_KEY=pplx-...

# ============================================================
# AgentMail — Network Agent email (Brief 079)
# ============================================================
# Sign up at https://console.agentmail.to for an API key
AGENTMAIL_API_KEY=am_...
AGENTMAIL_ALEX_INBOX=alex-ditto@agentmail.to
AGENTMAIL_MIRA_INBOX=mira-ditto@agentmail.to
# Webhook secret for validating inbound email signatures (Brief 098b)
# Set in AgentMail console when configuring webhooks
AGENTMAIL_WEBHOOK_SECRET=whsec_...

# ============================================================
# Unipile — Social Channel Ghost Mode (Brief 133)
# ============================================================
# Unified messaging API for LinkedIn DMs, WhatsApp, Instagram, Telegram.
# Sign up at https://www.unipile.com for API access.
# UNIPILE_DSN is the API base URL (e.g. https://api1.unipile.com:13111)
# UNIPILE_API_KEY is your access token.
# UNIPILE_DSN=https://api1.unipile.com:13111
# UNIPILE_API_KEY=...
# Social test mode allowlist: comma-separated Unipile attendee IDs
# DITTO_TEST_SOCIAL_IDS=attendee-id-1,attendee-id-2

# ============================================================
# X (Twitter) API v2 — Content Publishing (ADR-029, Brief 141)
# ============================================================
# Direct posting to X via API v2 (OAuth 1.0a single-user).
# Create a developer app at https://developer.x.com
# Pay-per-use: ~$0.01/tweet, ~$1-2/month at typical GTM volume.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# ============================================================
# Deployment (Brief 086)
# ============================================================
# PORT=3000                        # Server port (default: 3000)
# DATABASE_PATH=data/ditto.db      # SQLite database path (default: data/ditto.db)
#
# Deployment mode: "public" or "workspace" (default: "workspace")
# - public:    `/` renders front door for unauth'd visitors; `/welcome` and `/admin` accessible
# - workspace: `/` requires auth (→ /login); `/welcome` and `/admin` are hard-404'd
# Set to "public" on the main marketing/demo Railway service.
# DITTO_DEPLOYMENT=public

# ============================================================
# Network Service — API Token (Brief 088)
# ============================================================
# Token for workspace → network API authentication.
# Generate with: pnpm cli network token create --user-id <id>
# DITTO_NETWORK_TOKEN=dnt_...

# ============================================================
# Workspace → Network Connection (Brief 089)
# ============================================================
# Set these on the WORKSPACE side to connect to the Network Service.
# Production Network Service domain is https://ditto.partners (ADR-025).
# Railway URL below is a fallback for dev; production workspaces set the
# ditto.partners URL explicitly.
# DITTO_NETWORK_URL=https://ditto-network.up.railway.app
# DITTO_NETWORK_TOKEN=dnt_...

# ============================================================
# Network Service — Managed OAuth (Brief 187, ADR-031)
# ============================================================
# Set these on the NETWORK SERVICE side only. Never on a workspace.
# Each Ditto-owned OAuth app registers exactly one redirect URI:
# https://ditto.partners/v1/network/oauth/callback
# Secrets never written to DB, never logged, never sent over the bridge.
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# SLACK_OAUTH_CLIENT_ID=...            # Brief 189
# SLACK_OAUTH_CLIENT_SECRET=...        # Brief 189
# NOTION_OAUTH_CLIENT_ID=...           # Brief 190
# NOTION_OAUTH_CLIENT_SECRET=...       # Brief 190

# ============================================================
# Managed Workspace Provisioning — Railway (Brief 090, Brief 100)
# ============================================================
# Required for admin provisioning commands. Use a workspace-scoped
# Railway API token with deploy permissions.
# See: https://docs.railway.com/reference/public-api
# RAILWAY_API_TOKEN=...                   # Railway API token (workspace-scoped recommended)
# RAILWAY_PROJECT_ID=...                  # Railway project ID for workspace services
# DITTO_IMAGE_REF=ghcr.io/ditto/workspace:latest  # Docker image for workspaces

# ============================================================
# Fleet Upgrade Alerting (Brief 091, optional)
# ============================================================
# When set, upgrade failures and circuit breaker trips send a POST
# to this URL with a JSON payload. Works with Slack incoming webhooks,
# Discord webhooks, or any HTTP endpoint accepting POST + JSON.
# When not set, alerts are logged to stdout as structured JSON.
# DITTO_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ============================================================
# Workspace Auth — Magic Link Login (Brief 143)
# ============================================================
# When set, the workspace requires magic-link authentication.
# Only this email address can receive login links.
# When not set (local dev), workspace is accessible without auth.
# WORKSPACE_OWNER_EMAIL=you@example.com
# Base URL for magic link emails. Required when WORKSPACE_OWNER_EMAIL is set.
# Without this, magic links have no domain and won't work from email clients.
# NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
# SESSION_SECRET signs the workspace session cookie (HMAC-SHA256).
# Generate with: openssl rand -hex 32
# Required in production — without it, the secret falls back to
# WORKSPACE_OWNER_EMAIL which is guessable.
# SESSION_SECRET=

# ============================================================
# Admin Login (for /admin teammate view)
# ============================================================
# Simple username/password for the admin dashboard.
# Set on Railway or in .env. Required for /admin access.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Email address for admin notifications (trust downgrades, quality alerts).
# Brief 108: notifyAdmin() sends to this address.
ADMIN_EMAIL=

# ============================================================
# Test Mode — Safe Email Gate
# ============================================================
# When DITTO_TEST_MODE=true, emails are only sent to addresses
# in the DITTO_TEST_EMAILS allowlist. All other recipients are
# logged and suppressed. Prevents accidental outreach during testing.
DITTO_TEST_MODE=true
DITTO_TEST_EMAILS=you@example.com

# ============================================================
# Dev Pipeline — Telegram Bot (optional)
# ============================================================
# Create a bot via @BotFather on Telegram, get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Stripe — Per-Goal Budget Payments (Brief 107)
# ============================================================
# Stripe Checkout for loading funds into goal budgets.
# Sign up at https://dashboard.stripe.com
# Use test keys (sk_test_, whsec_test_) during development.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Cloudflare Turnstile — Bot Protection
# ============================================================
# Invisible CAPTCHA for front door chat endpoints.
# Sign up at https://dash.cloudflare.com/turnstile
# Leave unset for local development (requests pass through without verification).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# ============================================================
# Front Door Spend Ceiling
# ============================================================
# Daily spend limit (in cents) for all front-door LLM calls.
# When reached, visitors get a static "email me" response instead of LLM calls.
# Default: 1000 ($10/day). Resets at midnight UTC.
# FRONT_DOOR_DAILY_SPEND_LIMIT_CENTS=1000

# ============================================================
# Vapi — Voice Channel (Brief 142)
# ============================================================
# ElevenLabs Conversational AI — voice layer (STT + fast LLM + TTS)
# Our harness drives intelligence via server tools (webhooks).
# ELEVENLABS_API_KEY=                      # Server-side API key (xi-api-key)
# ELEVENLABS_AGENT_ID=                     # Optional — auto-created by ensureAgent() if not set
# ELEVENLABS_VOICE_ID=                     # ElevenLabs voice ID for Alex persona
# ELEVENLABS_SERVER_URL=                   # Base URL for server tool webhooks (e.g. https://ditto-dev.ngrok.app)

# Legacy Vapi config (deprecated — migrating to ElevenLabs)
# VAPI_PRIVATE_KEY=
# VAPI_ALEX_VOICE_ID=                      # Also used by ElevenLabs as fallback

# ============================================================
# Workspace Local Bridge (Brief 212)
# ============================================================
# HS256 signing key for device JWTs. Generate with:
#   openssl rand -base64 32
# 32+ random bytes; never commit. Required when paired devices dial in.
# BRIDGE_JWT_SIGNING_KEY=

# Public URL the daemon dials. Path-based topology per Brief 200 — sub-domain
# shapes are NOT assumed. Falls back to NEXT_PUBLIC_APP_URL with ws(s)://
# scheme + the canonical /api/v1/bridge/_dial path when unset.
#   Example: BRIDGE_DIAL_PUBLIC_URL=wss://workspace.example.com/api/v1/bridge/_dial
# BRIDGE_DIAL_PUBLIC_URL=
